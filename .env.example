# Server Configuration
PORT=3000 # development default is 3000
NODE_ENV=development # development or production
ENABLE_RATE_LIMIT=false # set to true to force rate limiting in development
SKIP_STARTUP_CONNECTION_TESTS=false # set to true to skip Mailchimp/Supabase startup checks
DISABLE_EMAIL_SENDING=false # set to true to skip outbound email while keeping routes functional
DISABLE_MAILCHIMP_SYNC=false # set to true to skip Mailchimp sync while keeping newsletter signup functional
LOG_LEVEL=info # e.g. trace, debug, info, warn, error, silent

# Supabase Configuration
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_HOST=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Mailchimp Configuration
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_LIST_ID=

# Resend Configuration
RESEND_API_KEY=

CONTACT_NOTIFICATION_EMAIL=sjba@stern.nyu.edu # Email to send contact form submissions to

# Security Configuration (local)
FRONTEND_URL=http://localhost:5173
# ADMIN_URL=http://localhost:5173

# Security Configuration (production)
# FRONTEND_URL=https://nyu-sjba.org
# ADMIN_URL=https://admin.nyu-sjba.org
