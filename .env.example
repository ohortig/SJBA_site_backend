# Server configuration
PORT=3000
NODE_ENV=development
ENABLE_RATE_LIMIT=false
LOG_LEVEL=info

# Local development safety switches
# Set these to true when running locally without touching external providers.
SKIP_STARTUP_CONNECTION_TESTS=true
DISABLE_EMAIL_SENDING=true
DISABLE_MAILCHIMP_SYNC=true

# Local Supabase
# From `supabase start`:
# - Project URL -> SUPABASE_URL
# - Publishable -> SUPABASE_PUBLISHABLE_KEY
# - Secret -> SUPABASE_SECRET_KEY (backend/admin routes only; never expose to browsers)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Local cloud snapshot workflow
SUPABASE_CLOUD_SNAPSHOT_DIR=supabase/.cloud-snapshot/latest
SUPABASE_DOWNLOAD_BUCKETS=board-headshots,event-flyers
SUPABASE_LOCAL_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Local callers
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Production/deployment values
# Never commit real production secrets. Set these in Vercel or your deployment environment.
# NODE_ENV=production
# SUPABASE_URL=https://ivhsrdfhjxtrxvrwswuk.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_M2Vg-sbCQbF2an3ZON699A_6HMwnEtX
# SUPABASE_SECRET_KEY=<production secret key>
# FRONTEND_URL=https://nyu-sjba.org
# ADMIN_URL=https://admin.nyu-sjba.org
# SKIP_STARTUP_CONNECTION_TESTS=false
# DISABLE_EMAIL_SENDING=false
# DISABLE_MAILCHIMP_SYNC=false

# Mailchimp configuration
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_LIST_ID=

# Resend configuration
RESEND_API_KEY=
CONTACT_NOTIFICATION_EMAIL=sjba@stern.nyu.edu
